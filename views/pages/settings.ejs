<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings</title>
    <%- include('../components/cdns') %>
</head>
<body class="d-flex flex-column vh-100">
    <%- include('../components/navbar') %>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <%- include('../components/sidebar') %>
    
        <main class="flex-grow-1 p-4 overflow-auto">

            <div class="container-fluid">
            
                <!-- Page Header -->
                <div class="mb-4">
                    <h4 class="fw-semibold mb-1">Settings</h4>
                    <p class="text-muted mb-0">Configure application, business, and security settings</p>
                </div>
            
                <div class="row g-4">
                
                    <!-- Left Navigation -->
                    <div class="col-lg-3">
                        <div class="card border-0 shadow-sm">
                            <div class="list-group list-group-flush">
                                <a href="#company" class="list-group-item list-group-item-action active">Company Settings</a>
                                <a href="#billing" class="list-group-item list-group-item-action">Billing & Tax</a>
                                <a href="#users" class="list-group-item list-group-item-action">User & Roles</a>
                                <a href="#security" class="list-group-item list-group-item-action">Security</a>
                                <a href="#system" class="list-group-item list-group-item-action">System</a>
                            </div>
                        </div>
                    </div>
                
                    <!-- Right Content -->
                    <div class="col-lg-9">
                    
                        <!-- Company Settings -->
                        <div id="company" class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-3">Company Information</h6>
                            
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Company Name</label>
                                        <input type="text" class="form-control" placeholder="Your Company Pvt Ltd">
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Business Email</label>
                                        <input type="email" class="form-control" placeholder="billing@company.com">
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Phone Number</label>
                                        <input type="text" class="form-control">
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">GST Number</label>
                                        <input type="text" class="form-control">
                                    </div>
                                
                                    <div class="col-12">
                                        <label class="form-label">Address</label>
                                        <textarea class="form-control" rows="3"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    
                        <!-- Billing & Tax -->
                        <div id="billing" class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-3">Billing & Tax Settings</h6>
                            
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label">Default Tax (%)</label>
                                        <input type="number" class="form-control" value="18">
                                    </div>
                                
                                    <div class="col-md-4">
                                        <label class="form-label">Invoice Prefix</label>
                                        <input type="text" class="form-control" value="INV-">
                                    </div>
                                
                                    <div class="col-md-4">
                                        <label class="form-label">Currency</label>
                                        <select class="form-select">
                                            <option value="INR">INR (₹)</option>
                                            <option value="USD">USD ($)</option>
                                            <option value="EUR">EUR (€)</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Payment Due Days</label>
                                        <input type="number" class="form-control" value="15">
                                    </div>
                                
                                    <div class="col-md-6 d-flex align-items-center">
                                        <div class="form-check mt-4">
                                            <input class="form-check-input" type="checkbox" checked>
                                            <label class="form-check-label">
                                                Enable automatic invoice numbering
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    
                        <!-- Users & Roles -->
                        <div id="users" class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-3">User & Role Defaults</h6>
                            
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Default Role for New Users</label>
                                        <select class="form-select">
                                            <option>Staff</option>
                                            <option>Viewer</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Max Login Attempts</label>
                                        <input type="number" class="form-control" value="5">
                                    </div>
                                </div>
                            </div>
                        </div>
                    
                        <!-- Security -->
                        <div id="security" class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-3">Security Settings</h6>
                            
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" checked>
                                            <label class="form-check-label">
                                                Enable JWT Authentication
                                            </label>
                                        </div>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox">
                                            <label class="form-check-label">
                                                Enable Two-Factor Authentication (2FA)
                                            </label>
                                        </div>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Session Timeout (minutes)</label>
                                        <input type="number" class="form-control" value="30">
                                    </div>
                                </div>
                            </div>
                        </div>
                    
                        <!-- System -->
                        <div id="system" class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-3">System Settings</h6>
                            
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Time Zone</label>
                                        <select class="form-select">
                                            <option>Asia/Kolkata</option>
                                            <option>UTC</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Date Format</label>
                                        <select class="form-select">
                                            <option>DD-MM-YYYY</option>
                                            <option>YYYY-MM-DD</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    
                        <!-- Save Button -->
                        <div class="d-flex justify-content-end mt-4">
                            <button class="btn btn-primary">
                                <i class="fa fa-save me-1"></i> Save Settings
                            </button>
                        </div>
                    
                    </div>
                </div>
            
            </div>

        </main>
    </div>

    <%- include('../components/footer') %>
</body>
</html>