<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports</title>
    <%- include('../components/cdns') %>
    <%- include('../components/meta') %>
</head>
<body class="d-flex flex-column vh-100 body-color">
    <%- include('../components/navbar') %>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <%- include('../components/sidebar') %>

        <main class="flex-grow-1 p-4 overflow-auto">

            <div class="container-fluid">
            
                <!-- Page Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-semibold mb-1">Reports</h4>
                        <p class="text-muted mb-0">Analyze revenue, invoices, and payment performance</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-warning btn-sm exportCSV">
                            <i class="fa fa-file-csv me-1"></i> Export CSV
                        </button>
                        <button class="btn btn-success btn-sm exportXLSX">
                            <i class="fa fa-file-excel me-1"></i> Export XLSX
                        </button>
                    </div>
                </div>
            
                <!-- Report Filters -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3">Filter Reports</h6>
                    
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">From Date</label>
                                <input type="date" class="form-control fromDate">
                            </div>
                        
                            <div class="col-md-3">
                                <label class="form-label">To Date</label>
                                <input type="date" class="form-control toDate">
                            </div>
                        
                            <div class="col-md-3">
                                <label class="form-label">Report Type</label>
                                <select class="form-select reportType">
                                    <option value="">Invoice & Payment</option>
                                    <option value="invoice">Invoice Report</option>
                                    <option value="payment">Payment Report</option>
                                </select>
                            </div>
                        
                            <div class="col-md-3 d-flex align-items-end">
                                <button class="btn btn-primary w-100 applyFilterBtn">
                                    <i class="fa fa-filter me-1"></i> Apply Filter
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            
                <!-- Summary Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Total Revenue</h6>
                                <h4 class="fw-bold mb-0">₹ <span class="revenue"></span></h4>
                            </div>
                        </div>
                    </div>
                
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Total Invoices (This Year)</h6>
                                <h4 class="fw-bold mb-0"><span class="invoice"></span></h4>
                            </div>
                        </div>
                    </div>
                
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Payments Received</h6>
                                <h4 class="fw-bold mb-0">₹ <span class="paymentRecived"></span></h4>
                            </div>
                        </div>
                    </div>
                
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Dues</h6>
                                <h4 class="fw-bold mb-0">₹ <span class="pendingDues"></span></h4>
                            </div>
                        </div>
                    </div>
                </div>
            
                <!-- Report Table -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                    
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0">Report Details</h6>
                            <input type="text" class="form-control form-control-sm w-25 searchInput" placeholder="Search report...">
                        </div>
                    
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr class="text-center">
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Reference</th>
                                        <th>Customer</th>
                                        <th>Email</th>
                                        <th>Type</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody class="reportTableBody">

                                </tbody>
                            </table>
                        </div>
                    
                    </div>
                </div>
            
            </div>

        </main>
    </div>
    <%- include('../components/footer') %>
    <script src="/js/report.js"></script>
</body>
</html>