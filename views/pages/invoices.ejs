<%- include('../components/footer') %>

<script>
    
document.addEventListener("DOMContentLoaded", () => {

    const statusSelect = document.getElementById("invoiceStatus");
    const paidWrapper = document.getElementById("paidAmountWrapper");
    const paymentModeWrapper = document.getElementById("paymentModeWrapper");
    const paidInput = document.querySelector('[name="paid_amount"]');
    const remainingText = document.getElementById("remainingAmount");

    function getTotal() {
        return parseFloat(
            document.querySelector(".invoice-total").innerText.replace(/[^\d.]/g, "")
        ) || 0;
    }
function updateUI() {
    const status = statusSelect.value;
    const total = getTotal();

    if (status === "pending") {
        paidWrapper.classList.add("d-none");
        paymentModeWrapper.classList.add("d-none");

        paidInput.value = "";
        paidInput.removeAttribute("readonly");

        remainingText.innerText = "0.00";
    }

    else if (status === "paid") {
        paidWrapper.classList.remove("d-none");
        paymentModeWrapper.classList.remove("d-none");

        paidInput.value = total.toFixed(2);
        paidInput.setAttribute("readonly", true);

        remainingText.innerText = "0.00";
    }

    else if (status === "due") {
        paidWrapper.classList.remove("d-none");
        paymentModeWrapper.classList.remove("d-none");

        paidInput.value = "";
        paidInput.removeAttribute("readonly");

        remainingText.innerText = total.toFixed(2);
    }
}

    function validateAndUpdateRemaining() {
        const total = getTotal();
        let paid = parseFloat(paidInput.value || 0);

        if (paid < 0) paid = 0;
        if (paid > total) {
            paid = total;
            paidInput.value = total;
        }

        const remaining = total - paid;
        remainingText.innerText = remaining.toFixed(2);

        // Optional visual feedback
        if (remaining === 0) {
            remainingText.style.color = "green";
        } else {
            remainingText.style.color = "red";
        }
    }

    statusSelect.addEventListener("change", updateUI);
    paidInput.addEventListener("input", validateAndUpdateRemaining);

});
    let inv_note = "Thank you for your business. Please ensure that payment is made within the due date mentioned above. Late payments may be subject to additional charges as per our terms and conditions.If you have any questions regarding this invoice, feel free to contact us. We appreciate your prompt attention to this matter and look forward to serving you again."
    document.querySelector("[name='notes']").innerHTML = inv_note;
function validateInvoiceForm() {
    const form = document.getElementById("invoiceForm");

    const prefix = form.invoice_prefix.value.trim();
    const invoiceNo = form.invoice_no.value.trim();
    const invoiceDate = form.invoice_date.value;
    const dueDate = form.due_date.value;
    const customerId = form.customer_id.value;
    const tax = form.tax.value;

    const itemsBody = document.getElementById("itemsTableBody");
    const itemRows = itemsBody.querySelectorAll("tr");

    if (prefix === "") {
        showToast("Invoice prefix is missing." , "warning");
        return false;
    }

    if (invoiceNo === "") {
        showToast("Invoice number is missing." , "warning");
        return false;
    }

    if (!invoiceDate) {
        showToast("Invoice date is required." , "warning");
        return false;
    }

    if (!dueDate) {
        showToast("Due date is required." , "warning");
        return false;
    }

    if (new Date(dueDate) < new Date(invoiceDate)) {
        showToast("Due date cannot be earlier than invoice date." , "warning");
        return false;
    }

    if (customerId === "") {
        showToast("Please select a customer." , "warning");
        return false;
    }

    /* ---------------- ITEMS VALIDATION ---------------- */

    if (itemRows.length === 0) {
        showToast("At least one invoice item is required." , "warning");
        return false;
    }

    /* ---------------- TAX & TOTAL ---------------- */

    if (tax !== "" && parseFloat(tax) < 0) {
        showToast("Tax percentage cannot be negative." , "warning");
        return false;
    }

    const totalText = document.querySelector(".invoice-total").innerText;
    const totalAmount = parseFloat(totalText.replace(/[^\d.]/g, ""));

    if (isNaN(totalAmount) || totalAmount <= 0) {
        showToast("Invoice total must be greater than zero." , "warning");
        return false;
    }


    return true;
}
async function downloadInvoice(id) {
    try {
        const res = await fetch(`/api/invoices/download/?id=${id}`, {
            method: "GET"
        });

        const contentType = res.headers.get("content-type");

        if (contentType && contentType.includes("application/json")) {
            const error = await res.json();
            showToast(error.msg || "Download failed", "danger");
            return;
        }

        const blob = await res.blob();

        if (!(blob instanceof Blob)) {
            showToast("Invalid file received", "danger");
            return;
        }

        const url = window.URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        
        const disposition = res.headers.get("content-disposition");
        let filename = "invoice.pdf";

        if (disposition) {
            const match = disposition.match(/filename\*?=(?:UTF-8'')?"?([^";\n]+)"?/i);
            if (match && match[1]) {
                filename = match[1];
            }
        }

        a.download = filename;

        
        document.body.appendChild(a);
        a.click();
        a.remove();

        window.URL.revokeObjectURL(url);

    } catch (err) {
        showToast(err.message || err, "danger");
    }
}


function printInvoice(id) {
    const width = 900;
    const height = 650;
    const left = (screen.width - width) / 2;
    const top = (screen.height - height) / 2;

    const features = `
        width=${width},
        height=${height},
        left=${left},
        top=${top},
        resizable=yes,
        scrollbars=yes,
        toolbar=no,
        menubar=no,
        location=no,
        status=no
    `;

    const printWindow = window.open(
        `/api/invoices/print?id=${id}`,
        'invoicePrint',
        features
    );

    if (!printWindow) {
        showToast("Popup blocked. Please allow popups." , "danger");
        return;
    }

    printWindow.onload = () => {
        printWindow.focus();
        printWindow.print();
    };

    window.addEventListener('focus', () => {
        printWindow.close();
    }, { once: true });
}



