<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payments</title>
    <%- include('../components/cdns') %>
</head>
<body class="d-flex flex-column vh-100">
    <%- include('../components/navbar') %>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <%- include('../components/sidebar') %>

        <main class="flex-grow-1 p-4 overflow-auto">

            <div class="container-fluid">
            
                <!-- Page Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-semibold mb-1">Payments</h4>
                        <p class="text-muted mb-0">Track and manage customer payments</p>
                    </div>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPaymentModal">
                        <i class="fa fa-credit-card me-1"></i> Record Payment
                    </button>
                </div>
            
                <!-- Stats Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Total Payments</h6>
                                <h3 class="fw-bold mb-0">₹ 98,450</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">This Month</h6>
                                <h3 class="fw-bold mb-0">₹ 24,300</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Pending Dues</h6>
                                <h3 class="fw-bold mb-0">₹ 26,550</h3>
                            </div>
                        </div>
                    </div>
                </div>
            
                <!-- Payments Table -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                    
                        <!-- Table Header -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0">Payment Records</h6>
                            <input type="text" class="form-control form-control-sm w-25" placeholder="Search payment...">
                        </div>
                    
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Customer</th>
                                        <th>Invoice</th>
                                        <th>Amount</th>
                                        <th>Mode</th>
                                        <th>Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>1</td>
                                        <td>2025-01-10</td>
                                        <td>John Doe</td>
                                        <td>INV-1021</td>
                                        <td>₹ 5,500</td>
                                        <td>UPI</td>
                                        <td>
                                            <span class="badge bg-success">Completed</span>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary">
                                                <i class="fa fa-eye"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                
                                    <tr>
                                        <td>2</td>
                                        <td>2025-01-08</td>
                                        <td>ABC Pvt Ltd</td>
                                        <td>INV-1019</td>
                                        <td>₹ 12,000</td>
                                        <td>Bank Transfer</td>
                                        <td>
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary">
                                                <i class="fa fa-eye"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    
                    </div>
                </div>
            
            </div>

            <!-- Add Payment Modal -->
            <div class="modal fade" id="addPaymentModal" tabindex="-1">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header">
                            <h5 class="modal-title">Record Payment</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                    
                        <form action="/payments/create" method="POST">
                            <div class="modal-body">
                                <div class="row g-3">
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Customer</label>
                                        <select name="customer_id" class="form-select" required>
                                            <option value="">Select Customer</option>
                                            <option value="1">John Doe</option>
                                            <option value="2">ABC Pvt Ltd</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Invoice</label>
                                        <select name="invoice_id" class="form-select" required>
                                            <option value="">Select Invoice</option>
                                            <option value="1021">INV-1021</option>
                                            <option value="1019">INV-1019</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-md-4">
                                        <label class="form-label">Amount</label>
                                        <input type="number" name="amount" class="form-control" step="0.01" required>
                                    </div>
                                
                                    <div class="col-md-4">
                                        <label class="form-label">Payment Mode</label>
                                        <select name="mode" class="form-select">
                                            <option>Cash</option>
                                            <option>UPI</option>
                                            <option>Card</option>
                                            <option>Bank Transfer</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-md-4">
                                        <label class="form-label">Payment Date</label>
                                        <input type="date" name="payment_date" class="form-control" required>
                                    </div>
                                
                                    <div class="col-12">
                                        <label class="form-label">Notes</label>
                                        <textarea name="notes" class="form-control" rows="3"></textarea>
                                    </div>
                                
                                </div>
                            </div>
                        
                            <div class="modal-footer">
                                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save me-1"></i> Save Payment
                                </button>
                            </div>
                        </form>
                    
                    </div>
                </div>
            </div>

        </main>
    </div>

    <%- include('../components/footer') %>
</body>
</html>