    function viewInvoice(id)
    {
        window.open(`/api/invoices/view/?id=${id}` , "_blank");
    }
    const searchInput = document.getElementById("searchInput");
    searchInput.addEventListener("keyup", () => {
        const filter = searchInput.value.toLowerCase();
        const rows = document.querySelectorAll("#invoiceTable tr");
        rows.forEach(row => {
            if (row.children.length < 2) return;
            const inv_no = row.children[1].innerText.toLowerCase();
            const name = row.children[2].innerText.toLowerCase();
            const date = row.children[3].innerText.toLowerCase();
            const amount = row.children[4].innerText.toLowerCase();
            if (inv_no.includes(filter) || name.includes(filter) || date.includes(filter) || amount.includes(filter)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    });
    function countEditItemsRow()
    {
        const invoiceTable = document.getElementById("editItemsBody");
        const rows = invoiceTable.rows.length;
        return rows;
