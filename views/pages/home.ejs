<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <%- include('../components/cdns') %>
    <%- include('../components/meta') %>
</head>
<body class="d-flex flex-column vh-100 body-color">
    <%- include('../components/navbar') %>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <%- include('../components/sidebar') %>

        <main class="flex-grow-1 p-4 overflow-auto">

            <div class="container-fluid">
            <!-- Page Title -->
            <div class="mb-4">
                <h4 class="fw-semibold">Dashboard Overview</h4>
                <p class="text-muted mb-0">Welcome <%= payload.fullname %></p>
            </div>
        
            <!-- Summary Cards -->
            <div class="row g-4 mb-4">
                <!-- Total Revenue -->
                <div class="col-xl-3 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-1">Total Revenue</h6>
                                    <h4 class="fw-bold mb-0">₹ <span class="revenue"></span></h4>
                                </div>
                                <div class="bg-success bg-opacity-10 text-success rounded-circle p-3">
                                    <i class="fa fa-wallet fa-lg"></i>
                                </div>
                            </div>
                            <small class="text-success">+12% from last month</small>
                        </div>
                    </div>
                </div>
            
                <!-- Total Invoices -->
                <div class="col-xl-3 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-1">Invoices</h6>
                                    <h4 class="fw-bold mb-0"><span class="invoiceCount"></span></h4>
                                </div>
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                    <i class="fa fa-file-invoice fa-lg"></i>
                                </div>
                            </div>
                            <small class="text-muted">This year</small>
                        </div>
                    </div>
                </div>
            
                <!-- Paid Payments -->
                <div class="col-xl-3 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-1">Payments Received</h6>
                                    <h4 class="fw-bold mb-0">₹ <span class="paymentRecived"></span></h4>
                                </div>
                                <div class="bg-info bg-opacity-10 text-info rounded-circle p-3">
                                    <i class="fa fa-credit-card fa-lg"></i>
                                </div>
                            </div>
                            <small class="text-muted">Completed payments</small>
                        </div>
                    </div>
                </div>
            
                <!-- Pending Dues -->
                <div class="col-xl-3 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-1">Dues</h6>
                                    <h4 class="fw-bold mb-0">₹ <span class="pendingDues"></span></h4>
                                </div>
                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3">
                                    <i class="fa fa-exclamation-circle fa-lg"></i>
                                </div>
                            </div>
                            <small class="text-danger">Requires attention</small>
                        </div>
                    </div>
                </div>
            </div>
        
            <!-- Secondary Cards -->
            <div class="row g-4">
                <!-- Customers -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="fw-semibold mb-3">Total Customers</h6>
                                    <h3 class="fw-bold"><span class="totalCustomers"></span></h3>
                                    <p class="text-muted mb-0">Active registered customers</p>
                                </div>
                                <div class="bg-success bg-opacity-10 text-primary rounded-circle p-3">
                                    <i class="fa fa-user fa-lg"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            
                <!-- Products -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="fw-semibold mb-3">Products / Services</h6>
                                    <h3 class="fw-bold"><span class="products"></span></h3>
                                    <p class="text-muted mb-0">Available items for billing</p>
                                </div>
                                <div class="bg-primary bg-opacity-10 text-warning rounded-circle p-3">
                                    <i class="fa fa-box fa-lg"></i>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            
                <!-- Recent Activity -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Recent Activity</h6>
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2">
                                    <small class="text-muted"><span class="recent1"></span></small>
                                </li>
                                <li class="mb-2">
                                    <small class="text-muted"><span class="recent2"></span></small>
                                </li>
                                <li>
                                    <small class="text-muted"><span class="recent3"></span></small>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <input type="hidden" name="" id="fullname" value="<%= payload.fullname %>">
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="liveToastSuccess" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
          <div class="toast-header bg-success text-light">
            <strong class="me-auto">Login</strong>
            <small>Just now</small>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
          </div>
          <div class="toast-body">
            <span class="successMsg"></span>
          </div>
        </div>
    </div>
        </main>
    </div>
    <script src="/js/home.js"></script>
    <%- include('../components/footer') %>
</body>
</html>