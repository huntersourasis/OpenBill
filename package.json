{
  "name": "billing-system",
  "version": "1.0.0",
  "description": "Billing System Desktop App",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --env-file .env server.js",
    "start": "electron .",
    "build": "electron-builder",
    "setup": "node --env-file .env setup.js",
    "update": "git pull origin main"
  },
  "build": {
    "appId": "com.billing.system",
    "productName": "OpenBILL",
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "puppeteer": "^24.34.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.11"
  }
}
