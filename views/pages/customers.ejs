<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customers</title>
    <%- include('../components/cdns') %>
    <%- include('../components/meta') %>
</head>
<body class="d-flex flex-column vh-100 body-color">
    <%- include('../components/navbar') %>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <%- include('../components/sidebar') %>

            <main class="flex-grow-1 p-4 overflow-auto">

                <div class="container-fluid">
                
                    <!-- Page Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h4 class="fw-semibold mb-1">Customers</h4>
                            <p class="text-muted mb-0">Manage your customers and billing details</p>
                        </div>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCustomerModal">
                            <i class="fa fa-user-plus me-1"></i> Add Customer
                        </button>
                    </div>
                
                    <!-- Stats Cards -->
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <h6 class="text-muted mb-1">Total Customers</h6>
                                    <h4 class="fw-bold mb-0 totalCustomers"></h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <h6 class="text-muted mb-1">Active Customers</h6>
                                    <h4 class="fw-bold mb-0 activeCustomers"></h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <h6 class="text-muted mb-1">Pending Payments</h6>
                                    <h4 class="fw-bold mb-0">₹ 00000</h4>
                                </div>
                            </div>
                        </div>
                    </div>
                
                    <!-- Customers Table -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                        
                            <!-- Table Header -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-semibold mb-0">Customer List</h6>
                                <input type="text" class="form-control form-control-sm w-25" id="searchInput" placeholder="Search customer...">
                            </div>
                        
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr class="text-center">
                                            <th>#</th>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Primary Phone</th>
                                            <th>Secondary Phone</th>
                                            <th>Total Invoices</th>
                                            <th>Due Amount</th>
                                            <th>Status</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="customerTable"></tbody>

                                    </tbody>
                                </table>
                            </div>
                        
                        </div>
                    </div>
                
                </div>

                <!-- Add Customer Modal -->
                <div class="modal fade" id="addCustomerModal" tabindex="-1">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content border-0 shadow">
                            <div class="modal-header">
                                <h5 class="modal-title">Add New Customer</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                        
                            <div>
                                <div class="modal-body">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Customer Name</label>
                                            <input type="text" id="name" class="form-control" required>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <label class="form-label">Email</label>
                                            <input type="email" id="email" class="form-control">
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <label class="form-label">Primary Phone</label>
                                            <input type="text" id="primary_phone" class="form-control">
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <label class="form-label">Secondary Phone</label>
                                            <input type="text" id="secondary_phone" class="form-control">
                                        </div>
                                    
                                        <div class="col-12">
                                            <label class="form-label">Address</label>
                                            <textarea id="address" class="form-control" rows="3"></textarea>
                                        </div>
                                    </div>
                                </div>
                            
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn btn-primary saveBtn">
                                        <i class="fa fa-save me-1"></i> Save Customer
                                    </button>
                                </div>
                            </div>
                        
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="editCustomerModal" tabindex="-1">
                  <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Customer</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                  
                      <div class="modal-body">
                        <input type="hidden" id="edit_id">
                    
                        <div class="row g-3">
                          <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input id="edit_name" class="form-control">
                          </div>
                      
                          <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input id="edit_email" class="form-control">
                          </div>
                      
                          <div class="col-md-6">
                            <label class="form-label">Primary Phone</label>
                            <input id="edit_primary" class="form-control">
                          </div>
                      
                          <div class="col-md-6">
                            <label class="form-label">Secondary Phone</label>
                            <input id="edit_secondary" class="form-control">
                          </div>
                      
                          <div class="col-12">
                            <label class="form-label">Address</label>
                            <textarea id="edit_address" class="form-control"></textarea>
                          </div>
                        </div>
                      </div>
                  
                      <div class="modal-footer">
                        <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary" onclick="updateCustomer()">Update</button>
                      </div>
                    </div>
                  </div>
                </div>

            <div class="modal fade" id="deleteConfirmModal" tabindex="-1">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title text-danger">Confirm Delete</h5>
                  </div>
                  <div class="modal-body">
                    Are you sure you want to delete this customer?
                    <input type="hidden" id="delete_id">
                  </div>
                  <div class="modal-footer">
                    <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger" onclick="deleteCustomer()">Delete</button>
                  </div>
                </div>
              </div>
            </div>

            <!-- View Customer Modal -->
            <div class="modal fade" id="viewCustomerModal" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content border-0 shadow">
                  <div class="modal-header">
                    <h5 class="modal-title">Customer Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
              
                  <div class="modal-body">
                    <div class="row g-3" id="viewCustomerBody">
                     
                    </div>
                    <div class="row g-3 mt-3" id="viewCustomerInvoice">
                      
                    </div>
                    <div class="row g-3 mt-3" id="viewCustomerCreationInfo">
                      
                    </div>
                  </div>
              
                  <div class="modal-footer">
                    <button class="btn btn-light" data-bs-dismiss="modal">Close</button>
                  </div>
                </div>
              </div>
            </div>
            <input type="hidden" id="user_email" value="<%= payload.email %>">
        </main>
    </div>

    <%- include('../components/footer') %>
    <script src="/js/customers.js"></script>
</body>
</html>