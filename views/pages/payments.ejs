<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payments</title>
    <%- include('../components/cdns') %>
    <%- include('../components/meta') %>
</head>
<body class="d-flex flex-column vh-100 body-color">
    <%- include('../components/navbar') %>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <%- include('../components/sidebar') %>

        <main class="flex-grow-1 p-4 overflow-auto">

            <div class="container-fluid">
            
                <!-- Page Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-semibold mb-1">Payments</h4>
                        <p class="text-muted mb-0">Track and manage customer payments</p>
                    </div>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPaymentModal">
                        <i class="fa fa-credit-card me-1"></i> Record Payment
                    </button>
                </div>
            
                <!-- Stats Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Total Payments</h6>
                                <h4 class="fw-bold mb-0">₹ <span class="total_payment"></span></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">This Month</h6>
                                <h4 class="fw-bold mb-0">₹ <span class="this_month"></span></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted mb-1">Dues</h6>
                                <h4 class="fw-bold mb-0">₹ <span class="dues"></span></h4>
                            </div>
                        </div>
                    </div>
                </div>
            
                <!-- Payments Table -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                    
                        <!-- Table Header -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0">Payment Records</h6>
                            <input type="text" class="form-control form-control-sm w-25" placeholder="Search payment...">
                        </div>
                    
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr class="text-center">
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Customer</th>
                                        <th>Invoice</th>
                                        <th>Amount</th>
                                        <th>Due</th>
                                        <th>Mode</th>
                                        <th>Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="paymentsTable">
                                    
                                </tbody>
                            </table>
                        </div>
                    
                    </div>
                </div>
            
            </div>

            <!-- Add Payment Modal -->
            <div class="modal fade" id="addPaymentModal" tabindex="-1">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header">
                            <h5 class="modal-title">Record Payment</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                    
                        <form id="paymentForm">
                            <div class="modal-body">
                                <div class="row g-3">
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Customer</label>
                                        <select name="customer_id" class="form-select" required>
                                            <option value="">Select Customer</option>

                                        </select>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Invoice</label>
                                        <select name="invoice_id" class="form-select" required>
                                            <option value="">Select Invoice</option>

                                        </select>
                                    </div>
                                
                                    <div class="col-md-4">
                                        <label class="form-label">Invoice Amount</label>
                                        <input type="number" name="amount" readonly class="form-control" step="0.01" required>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Paying Amount</label>
                                        <input type="number" name="p_amount" class="form-control" step="0.01" required>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Due Amount</label>
                                        <input type="number" name="d_amount" class="form-control" readonly step="0.01" required>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Payment Mode</label>
                                        <select name="mode" class="form-select">
                                            <option value="cash">Cash</option>
                                            <option value="UPI">UPI</option>
                                            <option value="card">Card</option>
                                            <option value="BT">Bank Transfer</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-md-6">
                                        <label class="form-label">Payment Date</label>
                                        <input type="date" name="payment_date" class="form-control" required>
                                    </div>
                                
                                    <div class="col-12">
                                        <label class="form-label">Notes</label>
                                        <textarea name="notes" class="form-control" rows="3"></textarea>
                                    </div>
                                
                                </div>
                            </div>
                        
                            <div class="modal-footer">
                                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save me-1"></i> Save Payment
                                </button>
                            </div>
                        </form>
                    
                    </div>
                </div>
            </div>

        </main>
    </div>
    <div class="modal fade" id="confirmActionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalTitle">Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="confirmModalMessage" class="mb-0 text-muted"></p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn" id="confirmModalBtn">
                    Confirm
                </button>
            </div>
        </div>
    </div>
</div>
<!-- Edit Payment Modal -->
<div class="modal fade" id="editPaymentModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">Edit Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="editPaymentForm">
                <div class="modal-body">
                    <input type="hidden" id="edit_payment_id">

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Customer</label>
                            <input type="text" id="edit_customer" class="form-control" readonly>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Invoice</label>
                            <input type="text" id="edit_invoice" class="form-control" readonly>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Invoice Amount</label>
                            <input type="number" id="edit_invoice_amount" class="form-control" readonly>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Paid Amount</label>
                            <input type="number" id="edit_paid_amount" class="form-control" step="0.01" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Due Amount</label>
                            <input type="number" id="edit_due_amount" class="form-control" readonly>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Payment Mode</label>
                            <select id="edit_payment_mode" class="form-select">
                                <option value="cash">Cash</option>
                                <option value="UPI">UPI</option>
                                <option value="card">Card</option>
                                <option value="BT">Bank Transfer</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Payment Date</label>
                            <input type="date" id="edit_payment_date" class="form-control" required>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea id="edit_notes" class="form-control" rows="3"></textarea>
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-save me-1"></i> Update Payment
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

    <%- include('../components/footer') %>

    <script src="/js/payment.js"></script>
</body>
</html>