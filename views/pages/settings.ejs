<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Settings</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../components/cdns') %>
</head>

<body class="d-flex flex-column vh-100 body-color">

<%- include('../components/navbar') %>

<div class="d-flex flex-grow-1 overflow-hidden">
    <%- include('../components/sidebar') %>

    <main class="flex-grow-1 p-4 overflow-auto">

        <div class="container-fluid">

            <div class="mb-4">
                <h4 class="fw-semibold mb-1">Settings</h4>
                <p class="text-muted mb-0">
                    Configure application, business, and security settings
                </p>
            </div>

            <div class="row g-4">

                <!-- LEFT NAV -->
                <div class="col-lg-3">
                    <div class="card border-0 shadow-sm">
                        <div class="list-group list-group-flush">
                            <a href="#company" class="list-group-item list-group-item-action active">Company Settings</a>
                            <a href="#billing" class="list-group-item list-group-item-action">Billing & Tax</a>
                            <a href="#users" class="list-group-item list-group-item-action">User & Roles</a>
                            <a href="#security" class="list-group-item list-group-item-action">Security</a>
                            <a href="#system" class="list-group-item list-group-item-action">System</a>
                        </div>
                    </div>
                </div>

                <!-- RIGHT CONTENT -->
                <div class="col-lg-9">

                    <!-- COMPANY -->
                    <div id="company" class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Company Information</h6>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Company Name</label>
                                    <input id="com_name" class="form-control">
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Business Email</label>
                                    <input id="business_email" type="email" class="form-control">
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Phone Number</label>
                                    <input id="ph_number" class="form-control">
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">GST Number</label>
                                    <input id="gst_number" class="form-control">
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Address</label>
                                    <textarea id="address" rows="3" class="form-control"></textarea>
                                </div>
                            </div>

                            <div class="text-end mt-3">
                                <button class="btn btn-primary" onclick="validateCompanyDetails(document.getElementById('ph_number').value , document.getElementById('gst_number').value , document.getElementById('business_email').value)">
                                    <i class="fa fa-save me-1"></i> Save Company
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- BILLING -->
                    <div id="billing" class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Billing & Tax Settings</h6>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">Default Tax (%)</label>
                                    <input id="default_tax" type="number" class="form-control">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Invoice Prefix</label>
                                    <input id="invoice_prefix" class="form-control">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Currency</label>
                                    <select id="currency" class="form-select">
                                        <option value="INR">INR (₹)</option>
                                        <option value="USD">USD ($)</option>
                                        <option value="EUR">EUR (€)</option>
                                    </select>
                                </div>

                                <div class="col-md-6 mt-2">
                                    <div class="form-check">
                                        <input id="automatic_invoice_numbering" type="checkbox" class="form-check-input">
                                        <label class="form-check-label">
                                            Enable automatic invoice numbering
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="text-end mt-3">
                                <button class="btn btn-primary" onclick="saveBilling()">
                                    <i class="fa fa-save me-1"></i> Save Billing
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- USER -->
                    <div id="users" class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">User & Role Defaults</h6>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Default Role</label>
                                    <select id="role" class="form-select" aria-readonly="true">
                                        <option value="user">User</option>
                                    </select>
                                </div>

                               
                            </div>

                            <div class="text-end mt-3">
                                <button class="btn btn-primary" onclick="saveUser()">
                                    <i class="fa fa-save me-1"></i> Save Users
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- SECURITY -->
                    <div id="security" class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Security Settings</h6>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Session Timeout (minutes)</label>
                                    <input id="session_timeout" type="number" class="form-control">
                                </div>
                                 <div class="col-md-6">
                                    <label class="form-label">Max Login Attempts</label>
                                    <input id="max_login_attempts" type="number" class="form-control">
                                </div>
                            </div>

                            <div class="text-end mt-3">
                                <button class="btn btn-primary" onclick="securityValidation(document.getElementById('max_login_attempts').value , document.getElementById('session_timeout').value);">
                                    <i class="fa fa-save me-1"></i> Save Security
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- SYSTEM -->
                    <div id="system" class="card border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">System Settings</h6>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Time Zone</label>
                                    <select id="time_zone" class="form-select">
                                        <option>Asia/Kolkata</option>
                                        <option>UTC</option>
                                    </select>
                                </div>
                            </div>

                            <div class="text-end mt-3">
                                <button class="btn btn-primary" onclick="saveSystem()">
                                    <i class="fa fa-save me-1"></i> Save System
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </main>
</div>


<%- include('../components/footer') %>


    <script src="/js/settings.js"></script>

</body>
</html>
