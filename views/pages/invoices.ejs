<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoices</title>

    <%- include('../components/cdns') %>
    <%- include('../components/meta') %>

    <style>
        /* View transition */
        .view {
            opacity: 0;
            transform: translateY(12px);
            transition: all 0.35s ease;
        }

        .active-view {
            opacity: 1;
            transform: translateY(0);
        }

        .d-none {
            display: none !important;
        }
        
        @media (min-width: 992px) {
            aside.d-none.d-lg-flex {
                display: flex !important;
            }
            .logout-text {
                display: block !important;
            }
        }
    </style>
</head>

<body class="d-flex flex-column vh-100 body-color">
<%- include('../components/navbar') %>

<div class="d-flex flex-grow-1 overflow-hidden">
    <%- include('../components/sidebar') %>

    <main class="flex-grow-1 p-4 overflow-auto">
        <div class="container-fluid">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-semibold mb-1" id="pageTitle">Create Invoice</h4>
                    <p class="text-muted mb-0" id="pageSubtitle">
                        Generate a new invoice for a customer
                    </p>
                </div>

                <div class="btn-group shadow-sm">
                    <button type="button" class="btn btn-primary active" id="btnCreateInvoice">
                        <i class="fa fa-plus me-1"></i> Create Invoice
                    </button>
                    <button type="button" class="btn btn-outline-primary" id="btnShowInvoices">
                        <i class="fa fa-file-invoice me-1"></i> Show Invoices
                    </button>
                </div>
            </div>

            <div id="createInvoiceView" class="view active-view">
                <form id="invoiceForm">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Invoice Details</h6>
                            <div class="row g-3">
                                <div class="col-md-1">
                                    <label class="form-label">Prefix</label>
                                    <input type="text" name="invoice_prefix" readonly class="form-control" required value="<%= settings.invoicePrefix %>">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Invoice Number</label>
                                    <input type="text" name="invoice_no" class="form-control" readonly required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Invoice Date</label>
                                    <input type="date" name="invoice_date" class="form-control" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Due Date</label>
                                    <input type="date" name="due_date" class="form-control" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Customer</label>
                                    <select name="customer_id" class="form-select" required>
                                        <option value="">Loading customers...</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Payment Status</label>
                                    <select name="status" class="form-select">
                                        <option value="pending">Pending</option>
                                        <option value="paid">Paid</option>
                                        <option value="due">Due</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Invoice Items</h6>
                            <div class="table-responsive">
                                <table class="table align-middle" id="itemsTable">
                                    <thead class="table-light">
                                    <tr>
                                        <th>Item</th>
                                        <th width="120">Qty</th>
                                        <th width="120">Stock</th>
                                        <th width="150">Rate</th>
                                        <th width="150">Total</th>
                                        <th width="50"></th>
                                    </tr>
                                    </thead>
                                    <tbody id="itemsTableBody">

                                    </tbody>
                                </table>
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="addItemBtn">
                                <i class="fa fa-plus me-1"></i> Add Item
                            </button>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-6 mb-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <h6 class="fw-semibold mb-3">Notes</h6>
                                    <textarea name="notes" class="form-control" rows="5"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 mb-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <h6 class="fw-semibold mb-3">Invoice Summary</h6>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Subtotal</span>
                                        <strong class="invoice-subtotal">₹ 0.00</strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Tax (%)</span>
                                        <input type="number" name="tax" class="form-control form-control-sm w-25 text-end">
                                    </div>
                                    <hr>
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold">Total</span>
                                        <span class="fw-bold fs-5 invoice-total">₹ 0.00</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" onclick="resetInvoice()" class="btn btn-light">Reset</button>
                        <button type="button" class="btn btn-success saveAndPrint">
                            <i class="fa fa-print me-1"></i> Save & Print Invoice
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-save me-1"></i> Save Invoice
                        </button>
                    </div>
                </form>
            </div>

            <div id="showInvoicesView" class="view d-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0">All Invoices</h6>
                            <input type="text" class="form-control form-control-sm w-25" id="searchInput" placeholder="Search invoice">
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                <tr class="text-center">
                                    <th>#</th>
                                    <th>Invoice No</th>
                                    <th>Customer</th>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Paid</th>
                                    <th>Due</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                                </thead>
                                <tbody id="invoiceTable">

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>
<!-- Edit Invoice Modal -->
<div class="modal fade" id="editInvoiceModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">Edit Invoice</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="editInvoiceForm">
                    <input type="hidden" name="invoice_id"> 
                    
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Customer Name</label>
                            <input type="text" name="name" class="form-control bg-light" readonly> 
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Invoice Number</label>
                            <input type="text" name="inv_number" class="form-control bg-light" readonly>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Invoice Date</label>
                            <input type="date" name="inv_date" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Due Date</label>
                            <input type="date" name="due_date" class="form-control"> 
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select"> 
                                <option value="pending">Pending</option>
                                <option value="paid">Paid</option>
                                <option value="due">Due</option>
                                <option value="cancelled">Cancelled</option> 
                            </select>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-semibold mb-0">Invoice Items</h6>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="addEditRow()"> 
                            <i class="fa fa-plus me-1"></i> Add Item
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th width="120">Qty</th>
                                    <th width="120">Stock</th> 
                                    <th width="150">Rate</th>
                                    <th width="150">Total</th>
                                    <th width="50"></th>
                                </tr>
                            </thead>
                            <tbody id="editItemsBody"></tbody> 
                        </table>
                    </div>

                    <div class="row mt-4 justify-content-end">
                        <div class="col-md-4">
                            <div class="card bg-light border-0">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-muted">Tax (%)</span>
                                        <input type="number" id="editTaxPercent" class="form-control form-control-sm w-50 text-end" oninput="updateEditSummary()"> 
                                    </div>
                                    <hr>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">Grand Total</span>
                                        <span class="fw-bold text-primary fs-5">₹ <span id="editInvoiceTotal">0.00</span></span> 
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="updateEditedInvoice()"> 
                    <i class="fa fa-save me-1"></i> Update Invoice
                </button>
            </div>
        </div>
    </div>
</div>
<!-- Delete Invoice Modal -->
<div class="modal fade" id="deleteInvoiceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title text-danger">Delete Invoice</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p class="mb-0">
                    Are you sure you want to permanently delete this invoice?
                </p>
                <input type="hidden" id="deleteInvoiceId">
            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" onclick="confirmDeleteInvoice()">Delete</button>
            </div>
        </div>
    </div>
</div>

<%- include('../components/footer') %>

<script>
function validateInvoiceForm() {
    const form = document.getElementById("invoiceForm");

    const prefix = form.invoice_prefix.value.trim();
    const invoiceNo = form.invoice_no.value.trim();
    const invoiceDate = form.invoice_date.value;
    const dueDate = form.due_date.value;
    const customerId = form.customer_id.value;
    const tax = form.tax.value;

    const itemsBody = document.getElementById("itemsTableBody");
    const itemRows = itemsBody.querySelectorAll("tr");

    /* ---------------- BASIC DETAILS ---------------- */

    if (prefix === "") {
        showToast("Invoice prefix is missing." , "warning");
        return false;
    }

    if (invoiceNo === "") {
        showToast("Invoice number is missing." , "warning");
        return false;
    }

    if (!invoiceDate) {
        showToast("Invoice date is required." , "warning");
        return false;
    }

    if (!dueDate) {
        showToast("Due date is required." , "warning");
        return false;
    }

    if (new Date(dueDate) < new Date(invoiceDate)) {
        showToast("Due date cannot be earlier than invoice date." , "warning");
        return false;
    }

    if (customerId === "") {
        showToast("Please select a customer." , "warning");
        return false;
    }

    /* ---------------- ITEMS VALIDATION ---------------- */

    if (itemRows.length === 0) {
        showToast("At least one invoice item is required." , "warning");
        return false;
    }

    /* ---------------- TAX & TOTAL ---------------- */

    if (tax !== "" && parseFloat(tax) < 0) {
        showToast("Tax percentage cannot be negative." , "warning");
        return false;
    }

    const totalText = document.querySelector(".invoice-total").innerText;
    const totalAmount = parseFloat(totalText.replace(/[^\d.]/g, ""));

    if (isNaN(totalAmount) || totalAmount <= 0) {
        showToast("Invoice total must be greater than zero." , "warning");
        return false;
    }

    /* ---------------- VALID ---------------- */

    return true;
}
function downloadInvoice(id)
{
    window.open(`/api/invoices/download/?id=${id}`);
}

function printInvoice(id) {
    const width = 900;
    const height = 650;
    const left = (screen.width - width) / 2;
    const top = (screen.height - height) / 2;

    const features = `
        width=${width},
        height=${height},
        left=${left},
        top=${top},
        resizable=yes,
        scrollbars=yes,
        toolbar=no,
        menubar=no,
        location=no,
        status=no
    `;

    const printWindow = window.open(
        `/api/invoices/print?id=${id}`,
        'invoicePrint',
        features
    );

    if (!printWindow) {
        showToast("Popup blocked. Please allow popups." , "danger");
        return;
    }

    printWindow.onload = () => {
        printWindow.focus();
        printWindow.print();
    };

    window.addEventListener('focus', () => {
        printWindow.close();
    }, { once: true });
}



function loadInvoice()
{
    fetch("/api/counter/load-invoice" , {
        method : "POST"
    }).then((res)=>{
        return res.json()
    }).then((data)=>{
        invoiceForm.invoice_no.value = data.data.inv_number;
    }).catch((err)=>{   
        showToast(err , "danger");
    })
}
function updateInvoice ()
{
    fetch("/api/counter/update-invoice" , {
        method : "POST"
    }).then((res)=>{
        return res.json();
    }).then((data)=>{
        if(!data.success) {
            showToast(err , "danger");
        }
    }).catch((err)=>{
        showToast(err , "danger");
    })
}

function resetInvoice() {
    invoiceForm.reset();
    const today = new Date().toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"]').forEach(input => input.value = today);
    document.querySelector('[name="tax"]').value = "<%= settings.defaultTax %>";
    itemsTableBody.innerHTML = "";
    loadInvoice();
    addNewRow();
    updateSummary();
    loadInvoiceTable();
}
    function getOrdinal(n) {
        const s = ["th", "st", "nd", "rd"];
        const v = n % 100;
        return s[(v - 20) % 10] || s[v] || s[0];
    }
    function formatDate(dateString) {
        const date = new Date(dateString);

        const day = date.getDate(); 

        const month = date.toLocaleString('default', { month: 'short' }); 

        const year = date.getFullYear(); 

        return `${day}${getOrdinal(day)} ${month}, ${year}`;
    }
    const btnCreate = document.getElementById('btnCreateInvoice');
    const btnShow = document.getElementById('btnShowInvoices');
    const createView = document.getElementById('createInvoiceView');
    const showView = document.getElementById('showInvoicesView');
    const title = document.getElementById('pageTitle');
    const subtitle = document.getElementById('pageSubtitle');
    const invoiceForm = document.getElementById('invoiceForm');
    const itemsTableBody = document.getElementById('itemsTableBody');
    const addItemBtn = document.getElementById('addItemBtn');

    let globalProducts = [];
    let selectedProducts = [];

    function switchView(showCreate) {
        if (showCreate) {
            showView.classList.add('d-none');
            createView.classList.remove('d-none');
            setTimeout(() => { createView.classList.add('active-view'); showView.classList.remove('active-view'); }, 10);
            btnCreate.className = 'btn btn-primary active';
            btnShow.className = 'btn btn-outline-primary';
            title.innerText = 'Create Invoice';
            subtitle.innerText = 'Generate a new invoice for a customer';
        } else {
            createView.classList.add('d-none');
            showView.classList.remove('d-none');
            setTimeout(() => { showView.classList.add('active-view'); createView.classList.remove('active-view'); }, 10);
            btnShow.className = 'btn btn-primary active';
            btnCreate.className = 'btn btn-outline-primary';
            title.innerText = 'Invoices';
            subtitle.innerText = 'View and manage all generated invoices';
        }
    }

    btnCreate.addEventListener('click', () => switchView(true));
    btnShow.addEventListener('click', () => switchView(false));

    async function initializeData() {
        try {
            const [custRes, prodRes] = await Promise.all([
                fetch('/api/customers/read', { method: "POST", headers: { "Content-Type": "application/json" } }),
                fetch('/api/products/read', { method: "POST", headers: { "Content-Type": "application/json" } })
            ]);

            const customersData = await custRes.json();
            const productsData = await prodRes.json();

            const customers = customersData.data.customers || [];
            globalProducts = productsData.data || [];

            const customerSelect = document.querySelector('select[name="customer_id"]');
            customerSelect.innerHTML = '<option value="">Select Customer</option>';
            customers.forEach(c => {
                customerSelect.innerHTML += `<option value="${c._id}">${c.name} (${c.email})</option>`;
            });


            addNewRow();

        } catch (err) {
            console.error("Error loading initial data:", err);
            showToast("Failed to load customer/product data." , "danger");
        }
    }


function addNewRow() {
    const row = document.createElement('tr');
    row.innerHTML = `
        <td>
            <select name="product_id[]" class="form-select product-select" required>
                </select>
            <input type="hidden" name="item_name[]">
        </td>
        <td><input type="number" name="quantity[]" class="form-control" min="1" value="1"></td>
        <td><input type="number" readonly name="stock[]" class="form-control" min="0" ></td>
        <td><input type="number" name="price[]" class="form-control" step="0.01" value="0"></td>
        <td><input type="text" class="form-control row-total" readonly value="0.00"></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger remove-item"><i class="fa fa-trash"></i></button></td>
    `;
    itemsTableBody.appendChild(row);
    updateAllDropdowns();
}

    function updateAllDropdowns() {
        const allSelects = document.querySelectorAll('.product-select');
        const currentlySelectedIds = Array.from(allSelects)
            .map(select => select.value)
            .filter(id => id !== "");

        allSelects.forEach(select => {
            const currentValue = select.value;

            let html = '<option value="">Select Product</option>';

            globalProducts.forEach(p => {
                const isSelectedElsewhere = currentlySelectedIds.includes(p._id) && p._id !== currentValue;

                if (!isSelectedElsewhere) {
                    html += `<option value="${p._id}" 
                                data-price="${p.price}" 
                                data-stock="${p.stock}" 
                                ${p._id === currentValue ? 'selected' : ''}>
                                ${p.category} → ${p.name} → ${p.sku}
                             </option>`;
                }
            });

            select.innerHTML = html;
        });
    }
    addItemBtn.addEventListener('click', addNewRow);

    itemsTableBody.addEventListener('click', (e) => {
        if (e.target.closest('.remove-item')) {
            if (itemsTableBody.rows.length > 1) {
                e.target.closest('tr').remove();
                updateSummary();
                updateAllDropdowns();
            }
        }
    });

    itemsTableBody.addEventListener('change', (e) => {
        if (e.target.classList.contains('product-select')) {
            const row = e.target.closest('tr');
            const selectedOption = e.target.options[e.target.selectedIndex];
            const price = selectedOption.dataset.price || 0;
            const stock = selectedOption.dataset.stock || 0;
            
            row.querySelector('[name="price[]"]').value = price;
            row.querySelector('[name="stock[]"]').value = stock;
            row.querySelector('[name="item_name[]"]').value = selectedOption.text;
            calculateRowTotal(row);
            updateAllDropdowns();
        }
    });

    itemsTableBody.addEventListener('input', (e) => {
        if (e.target.name === 'quantity[]') {
            const row = e.target.closest('tr');
            const productSelect = row.querySelector('.product-select');
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            const stock = Number(selectedOption.dataset.stock || 0);
            let quantity = Number(e.target.value);
            if (quantity > stock) {
                e.target.value = stock;
                if (typeof showToast === 'function') {
                    showToast(`Maximum available stock is ${stock}`, "warning");
                } else {
                    showToast(`Maximum available stock is ${stock}` , "warning");
                }
            }
            calculateRowTotal(row);
        }
    });

    itemsTableBody.addEventListener('input', (e) => {
        if (e.target.name === 'quantity[]' || e.target.name === 'price[]') {
            calculateRowTotal(e.target.closest('tr'));
        }
    });

    function calculateRowTotal(row) {
        const qty = Number(row.querySelector('[name="quantity[]"]').value || 0);
        const price = Number(row.querySelector('[name="price[]"]').value || 0);
        const total = qty * price;
        row.querySelector('.row-total').value = total.toFixed(2);
        updateSummary();

    }

    function updateSummary() {
        let subtotal = 0;
        document.querySelectorAll('.row-total').forEach(input => {
            subtotal += Number(input.value || 0);
        });

        const taxPercent = Number(document.querySelector('[name="tax"]').value || 0);
        const taxAmount = subtotal * (taxPercent / 100);
        const total = subtotal + taxAmount;

        document.querySelector('.invoice-subtotal').innerText = `₹ ${subtotal.toLocaleString('en-IN', {minimumFractionDigits: 2})}`;
        document.querySelector('.invoice-total').innerText = `₹ ${total.toLocaleString('en-IN', {minimumFractionDigits: 2})}`;
    }

    async function saveInvoice()
    {
            const productIds = document.getElementsByName('product_id[]');
            const names = document.getElementsByName('item_name[]');
            const qtys = document.getElementsByName('quantity[]');
            const prices = document.getElementsByName('price[]');

            const items = [];
            for (let i = 0; i < productIds.length; i++) {
                if (!productIds[i].value) continue;
                items.push({
                    product_id: productIds[i].value,
                    name: names[i].value,
                    quantity: Number(qtys[i].value),
                    rate: Number(prices[i].value)
                });
            }

            if (items.length === 0) {
                showToast("Please add at least one product to the invoice." , "warning");
                return;
            }

            const payload = {
                inv_number: "<%= settings.invoicePrefix %>" + "-" + invoiceForm.invoice_no.value,
                inv_date: invoiceForm.invoice_date.value,
                due_date: invoiceForm.due_date.value,
                customer_id: invoiceForm.customer_id.value,
                status: invoiceForm.status.value,
                tax_percent: Number(invoiceForm.tax.value || 0),
                notes: invoiceForm.notes.value,
                items: items,
                created_by : "<%= payload.id %>"
            };

            try {
                const response = await fetch('/api/invoices/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success) {
                    showToast('Invoice Created Successfully!' , "success");
                    updateInvoice();
                    setTimeout(()=>{
                        resetInvoice();
                    } , 1000);
                    return result.data;
                } else {
                    showToast('Error: ' + (result.message || 'Submission failed') , "warning");
                }
            } catch (error) {
                console.error("Submission Error:", error);
                showToast('A server error occurred.' , "danger");
            }
    }

    document.querySelector('[name="tax"]').addEventListener('input', updateSummary);


        invoiceForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            await saveInvoice();
        });

        document.querySelector(".saveAndPrint").addEventListener("click" , async (e)=>{
            e.preventDefault();
            if(validateInvoiceForm())
            {
                const data = await saveInvoice();
                printInvoice(data._id);
            }
        })

        function loadInvoiceTable() {
        const invoiceTableBody = document.getElementById("invoiceTable");

        invoiceTableBody.innerHTML = '<tr><td colspan="7" class="text-center">Loading invoices...</td></tr>';

        fetch("/api/invoices/read", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            }
        })
        .then(res => {
            if (!res.ok) throw new Error("Failed to fetch invoices");
            return res.json();
        })
        .then(result => {
            invoiceTableBody.innerHTML = "";

            const invoices = result.data || [];

            if (invoices.length === 0) {
                invoiceTableBody.innerHTML = '<tr><td colspan="9" class="text-center">NO INVOICES FOUND</td></tr>';
                return;
            }

            invoices.forEach((inv, i) => {
                const date = inv.inv_date ? new Date(inv.inv_date).toLocaleDateString() : 'N/A';

                const customerName = (inv.customer_id && inv.customer_id.name) 
                                     ? inv.customer_id.name 
                                     : (inv.customer_id || "Unknown");

                const statusClass = inv.status === 'paid' ? 'bg-success' : 
                                    inv.status === 'pending' ? 'bg-warning text-dark' : 'bg-danger';

                const row = `
                    <tr class='text-center'>
                        <td>${i + 1}</td>    
                        <td><strong>${inv.inv_number}</strong></td>    
                        <td>${customerName}</td>    
                        <td>${formatDate(date)}</td>
                        <td class="fw-bold">₹ ${Number(inv.total_amount || 0).toLocaleString('en-IN', {minimumFractionDigits: 2})}</td> 
                        <td class="fw-bold">₹ ${Number(inv.paid_amount || 0).toLocaleString('en-IN', {minimumFractionDigits: 2})}</td> 
                        <td class="fw-bold">₹ ${Number((inv.total_amount) - Number(inv.paid_amount || 0)).toLocaleString('en-IN', {minimumFractionDigits: 2})}</td> 
                        <td><span class="badge ${statusClass}">${inv.status.toUpperCase()}</span></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button onclick="viewInvoice('${inv._id}')" class="btn btn-outline-secondary"><i class="fa fa-eye"></i></button>
                                <button onclick="printInvoice('${inv._id}')" class="btn btn-outline-success"><i class="fa fa-print"></i></button>
                                <button onclick="downloadInvoice('${inv._id}')" class="btn btn-outline-info"><i class="fa fa-download"></i></button>
                                <button onclick="editInvoice('${inv._id}')" class="btn btn-outline-warning"><i class="fa fa-edit"></i></button>
                                <button onclick="deleteInvoice('${inv._id}')" class="btn btn-outline-danger"><i class="fa fa-trash"></i></button>
                            </div>
                        </td>    
                    </tr>
                `;
                invoiceTableBody.insertAdjacentHTML('beforeend', row);
            });
        })
        .catch(err => {
            console.error("Error:", err);
            invoiceTableBody.innerHTML = `<tr><td colspan="7" class="text-center text-danger">Error: ${err.message}</td></tr>`;
        });
    }

function addEditRow(item = null) {
    const tbody = document.getElementById("editItemsBody");
    const row = document.createElement('tr');
    
    let options = globalProducts.map(p => 
        `<option value="${p._id}" data-price="${p.price}" data-stock="${p.stock}" ${item && item.product_id === p._id ? 'selected' : ''}>
            ${p.name} (${p.sku})
        </option>`
    ).join('');

    row.innerHTML = `
        <td>
            <select class="form-select form-select-sm edit-product-select">
                <option value="">Select</option>
                ${options}
            </select>
        </td>
        <td><input type="number" class="form-control form-control-sm edit-qty" min="1" value="${item ? item.quantity : 1}"></td>
        <td><input type="number" class="form-control form-control-sm edit-stock bg-light" readonly value="${item ? (globalProducts.find(p=>p._id === item.product_id)?.stock || 0) : 0}"></td>
        <td><input type="number" class="form-control form-control-sm edit-rate" value="${item ? item.rate : 0}"></td>
        <td class="edit-row-total">₹ ${(item ? item.quantity * item.rate : 0).toFixed(2)}</td>
        <td><button type="button" class="btn btn-sm text-danger" onclick="
        if (countEditItemsRow() > 1) {
            this.closest('tr').remove();
            updateEditSummary();
        } else {
            showToast('There should be at least one item', 'warning');
        }
        "><i class="fa fa-trash"></i></button></td>
    `;
    tbody.appendChild(row);

    row.addEventListener('input', (e) => {
        const qtyInput = row.querySelector('.edit-qty');
        const stockInput = row.querySelector('.edit-stock');
        const productSelect = row.querySelector('.edit-product-select');
        
        if (e.target.classList.contains('edit-product-select')) {
            const opt = productSelect.options[productSelect.selectedIndex];
            const stock = Number(opt.dataset.stock || 0);
            row.querySelector('.edit-rate').value = opt.dataset.price || 0;
            stockInput.value = stock;
        }

        if (e.target.classList.contains('edit-qty')) {
            const maxStock = Number(stockInput.value);
            if (Number(qtyInput.value) > maxStock) {
                qtyInput.value = maxStock;
                showToast(`Maximum available stock is ${maxStock}`, "warning");
            }
        }
        
        updateEditSummary();
    });
}
function updateEditSummary() {
    let subtotal = 0;
    document.querySelectorAll('#editItemsBody tr').forEach(row => {
        const qty = row.querySelector('.edit-qty').value;
        const rate = row.querySelector('.edit-rate').value;
        const total = qty * rate;
        row.querySelector('.edit-row-total').innerText = `₹ ${total.toFixed(2)}`;
        subtotal += total;
    });
    
    const tax = document.getElementById('editTaxPercent').value || 0;
    const finalTotal = subtotal + (subtotal * tax / 100);
    document.getElementById("editInvoiceTotal").innerText = finalTotal.toLocaleString('en-IN');
}

async function editInvoice(id) {
    try {
        const res = await fetch(`/api/invoices/read-one/`, { 
            method: "POST", 
            headers: {"Content-Type": "application/json"}, 
            body: JSON.stringify({ id }) 
        });
        const result = await res.json();
        const inv = result.data;

        const form = document.getElementById("editInvoiceForm");
        form.invoice_id.value = inv._id;
        form.inv_number.value = inv.inv_number;
        form.name.value = inv.customer_id.name;
        form.status.value = inv.status;
        
        form.inv_date.value = inv.inv_date ? new Date(inv.inv_date).toISOString().split('T')[0] : "";
        form.due_date.value = inv.due_date ? new Date(inv.due_date).toISOString().split('T')[0] : "";

        document.getElementById('editTaxPercent').value = inv.tax_percent;
        document.getElementById("editItemsBody").innerHTML = "";
        inv.items.forEach(item => addEditRow(item));
        updateEditSummary();

        new bootstrap.Modal(document.getElementById("editInvoiceModal")).show();
    } catch (err) {
        showToast("Error loading invoice", "danger");
    }
}

async function updateEditedInvoice() {
    const form = document.getElementById("editInvoiceForm");
    const rows = document.querySelectorAll("#editItemsBody tr");
    const items = [];

    rows.forEach(row => {
        const select = row.querySelector(".edit-product-select");
        if (select.value) {
            items.push({
                product_id: select.value,
                name: select.options[select.selectedIndex].text,
                quantity: Number(row.querySelector(".edit-qty").value),
                rate: Number(row.querySelector(".edit-rate").value)
            });
        }
    });

    try {
        const res = await fetch("/api/invoices/update", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                id: form.invoice_id.value,
                updateData: {
                    items: items,
                    status: form.status.value,
                    inv_date: form.inv_date.value, 
                    due_date: form.due_date.value,  
                    tax_percent: Number(document.getElementById('editTaxPercent').value)
                }
            })
        });
        const result = await res.json();
        if (!result.success) throw new Error(result.message);

        showToast("Invoice updated successfully", "success");
        bootstrap.Modal.getInstance(document.getElementById("editInvoiceModal")).hide();
        loadInvoiceTable();
    } catch (err) {
        showToast(err.message, "danger");
    }
}

    function deleteInvoice(id) {
        document.getElementById("deleteInvoiceId").value = id;
        new bootstrap.Modal(document.getElementById("deleteInvoiceModal")).show();
    }

    async function confirmDeleteInvoice() {
        const id = document.getElementById("deleteInvoiceId").value;

        try {
            const res = await fetch(`/api/invoices/delete/`, {
                method: "POST",
                headers : {
                    "Content-Type" : "application/json"
                } ,
                body : JSON.stringify({
                    id : id
                })
            });
            const result = await res.json();
            if (!result.success) throw new Error(result.message);

            showToast("Invoice deleted successfully", "success");
            bootstrap.Modal.getInstance(
                document.getElementById("deleteInvoiceModal")
            ).hide();

            loadInvoiceTable();
        } catch (err) {
            showToast(err.message, "danger");
        }
    }


    function viewInvoice(id)
    {
        window.open(`/api/invoices/view/?id=${id}` , "_blank");
    }
    const searchInput = document.getElementById("searchInput");
    searchInput.addEventListener("keyup", () => {
        const filter = searchInput.value.toLowerCase();
        const rows = document.querySelectorAll("#invoiceTable tr");
        rows.forEach(row => {
            if (row.children.length < 2) return;
            const inv_no = row.children[1].innerText.toLowerCase();
            const name = row.children[2].innerText.toLowerCase();
            const date = row.children[3].innerText.toLowerCase();
            const amount = row.children[4].innerText.toLowerCase();
            if (inv_no.includes(filter) || name.includes(filter) || date.includes(filter) || amount.includes(filter)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    });
    function countEditItemsRow()
    {
        const invoiceTable = document.getElementById("editItemsBody");
        const rows = invoiceTable.rows.length;
        return rows;
    }
    document.addEventListener('DOMContentLoaded', () => {
        loadInvoice();
        const today = new Date().toISOString().split('T')[0];
        document.querySelectorAll('input[type="date"]').forEach(input => input.value = today);
        document.querySelector('[name="tax"]').value = "<%= settings.defaultTax %>";
        initializeData();
        loadInvoiceTable();
    });
</script>

</body>
</html>