<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products</title>
    <%- include('../components/cdns') %>
</head>

<body class="d-flex flex-column vh-100 body-color">
<%- include('../components/navbar') %>

<div class="d-flex flex-grow-1 overflow-hidden">
<%- include('../components/sidebar') %>

<main class="flex-grow-1 p-3 p-md-4 overflow-auto">
<div class="container-fluid">

<!-- HEADER -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
    <div>
        <h4 class="fw-semibold mb-1">Products & Services</h4>
        <p class="text-muted mb-0">Manage products, categories and SKU rules</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#categoryModal">
            <i class="fa fa-folder me-1"></i> Categories
        </button>
        <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#skuModal">
            <i class="fa fa-barcode me-1"></i> SKU Rules
        </button>
        <button class="btn btn-primary" id="addProductBtn" data-bs-toggle="modal" data-bs-target="#productModal">
            <i class="fa fa-plus me-1"></i> Add Product
        </button>
    </div>
</div>

<!-- STATS -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <small class="text-muted">Total Products</small>
                <h4 class="fw-bold mb-0" id="totalProducts"></h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <small class="text-muted">Active Products</small>
                <h4 class="fw-bold mb-0" id="activeProducts"></h4>
            </div>
        </div>
    </div>
    <div class="col-sm-12 col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <small class="text-muted">Out of Stock</small>
                <h4 class="fw-bold mb-0" id="outOfStock"></h4>
            </div>
        </div>
    </div>
</div>

<!-- PRODUCT TABLE -->
<div class="card border-0 shadow-sm">
<div class="card-body">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Products List</h6>
        <input id="searchInput" type="text"
               class="form-control form-control-sm w-25"
               placeholder="Search user...">
    </div>

<div class="table-responsive">
<table class="table table-hover align-middle">
<thead class="table-light">
<tr class="text-center">
    <th>#</th>
    <th>Name</th>
    <th>Category</th>
    <th>SKU</th>
    <th>Warrranty(M)</th>
    <th>Price</th>
    <th>Tax (%)</th>
    <th>Stock</th>
    <th>Status</th>
    <th class="text-end">Actions</th>
</tr>
</thead>
<tbody id="productTableBody">

</tbody>
</table>
</div>

</div>
</div>

</div>

<!-- PRODUCT MODAL -->
<div class="modal fade" id="productModal">
<div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
<div class="modal-content border-0 shadow">
<div>

<div class="modal-header">
    <h5 class="modal-title">Add Product</h5>
    <button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <input type="hidden" name="productId">
<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Product Name</label>
        <input class="form-control" name="name" required>
    </div>
    <div class="col-md-6">
        <label class="form-label">SKU</label>
        <select class="form-select" name="sku" id="productSkuRule" required>
            <option value="">Select SKU Rule</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Price</label>
        <input type="number" class="form-control" name="price">
    </div>
    <div class="col-md-3">
        <label class="form-label">Stock</label>
        <input type="number" class="form-control" name="stock">
    </div>
    <div class="col-md-3">
        <label class="form-label">Tax (%)</label>
        <input type="number" class="form-control" name="tax" value="<%= settings.defaultTax %>">
    </div>
    <div class="col-md-3">
        <label class="form-label">Warrranty (Months)</label>
        <input type="number" class="form-control" name="warranty" value="1">
    </div>
    <div class="col-12">
        <label class="form-label">Description</label>
        <textarea class="form-control" rows="3"></textarea>
    </div>
</div>
</div>

<div class="modal-footer">
    <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-primary" id="saveProductBtn"><i class="fa fa-save me-1"></i> Save</button>
    <button class="btn btn-success d-none" id="updateProductBtn"><i class="fa fa-edit me-1"></i> Update</button>
</div>

</div>
</div>
</div>
</div>

<!-- CATEGORY MODAL -->
<div class="modal fade" id="categoryModal">
<div class="modal-dialog modal-md modal-dialog-centered modal-dialog-scrollable">
<div class="modal-content border-0 shadow">

<div class="modal-header">
    <h5 class="modal-title">Manage Categories</h5>
    <button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
<div class="mb-3">
    <label class="form-label">New Category</label>
    <div class="input-group">
        <input class="form-control" id="category" placeholder="Category">
        <button class="btn btn-primary addCategoryBtn">Add</button>
    </div>
</div>

<ul class="list-group" id="categoryList">
    <li class="list-group-item d-flex align-items-center">
        <input 
            type="text" 
            class="form-control flex-grow-1 me-2"
            value="CCTV" readonly
        >
        <div class="btn-group">
            <button class="btn btn-sm btn-outline-warning">
                <i class="fa fa-edit"></i>
            </button>
            <button class="btn btn-sm btn-outline-danger">
                <i class="fa fa-trash"></i>
            </button>
        </div>
    </li>
</ul>

</div>

</div>
</div>
</div>

<!-- SKU MODAL -->
<div class="modal fade" id="skuModal">
<div class="modal-dialog modal-md modal-dialog-centered modal-dialog-scrollable">
<div class="modal-content border-0 shadow">

<div class="modal-header">
    <h5 class="modal-title">SKU Rules</h5>
    <button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
<div class="row g-2 mb-3">
    <div class="col-6">
        <select class="form-select" id="skuCategory">
            <option value="">Select Category</option>
        </select>
    </div>
    <div class="col-6">
        <input class="form-control" id="skuPrefix" placeholder="SKU">
    </div>
    <div class="col-12">
        <button class="btn btn-success w-100" id="saveSkuRuleBtn">Save Rule</button>
    </div>
</div>

<ul class="list-group" id="skuRuleList">

</ul>
</div>

</div>
</div>
</div>

</main>
</div>
<div class="modal fade" id="confirmDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    <i class="fa fa-triangle-exclamation me-1"></i> Confirm Deletion
                </h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p class="mb-0">
                    This action will permanently delete the category.
                    <br>
                    <strong>Are you sure you want to continue?</strong>
                </p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa fa-trash me-1"></i> Delete
                </button>
            </div>

        </div>
    </div>
</div>


<%- include('../components/footer') %>

<script src="/js/products.js"></script>

</body>
</html>