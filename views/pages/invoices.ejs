<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoices</title>

    <%- include('../components/cdns') %>
    <%- include('../components/meta') %>

    <style>
        /* View transition */
        .view {
            opacity: 0;
            transform: translateY(12px);
            transition: all 0.35s ease;
        }

        .active-view {
            opacity: 1;
            transform: translateY(0);
        }

        .d-none {
            display: none !important;
        }
        
        @media (min-width: 992px) {
            aside.d-none.d-lg-flex {
                display: flex !important;
            }
            .logout-text {
                display: block !important;
            }
        }
    </style>
</head>

<body class="d-flex flex-column vh-100 body-color">
<%- include('../components/navbar') %>

<div class="d-flex flex-grow-1 overflow-hidden">
    <%- include('../components/sidebar') %>

    <main class="flex-grow-1 p-4 overflow-auto">
        <div class="container-fluid">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-semibold mb-1" id="pageTitle">Create Invoice</h4>
                    <p class="text-muted mb-0" id="pageSubtitle">
                        Generate a new invoice for a customer
                    </p>
                </div>
                <div id="bulkActions" class="btn-group shadow-sm d-none">
                    <button class="btn btn-outline-secondary" onclick="bulkView()" style="border-radius: 10px; margin: 5px;">
                        <i class="fa fa-eye me-1"></i> View
                    </button>
                    <button class="btn btn-outline-dark" onclick="bulkDownload()" style="border-radius: 10px; margin: 5px;">
                        <i class="fa fa-download me-1"></i> Download
                    </button>
                </div>
                <div class="btn-group shadow-sm">
                    <button type="button" class="btn btn-primary active" id="btnCreateInvoice">
                        <i class="fa fa-plus me-1"></i> Create Invoice
                    </button>
                    <button type="button" class="btn btn-outline-primary" id="btnShowInvoices">
                        <i class="fa fa-file-invoice me-1"></i> Show Invoices
                    </button>
                </div>
            </div>

            <div id="createInvoiceView" class="view active-view">
                <form id="invoiceForm">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Invoice Details</h6>
                            <div class="row g-3">
                                <div class="col-md-1">
                                    <label class="form-label">Prefix</label>
                                    <input type="text" name="invoice_prefix" readonly class="form-control" required value="<%= settings.invoicePrefix %>">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Invoice Number</label>
                                    <input type="text" name="invoice_no" class="form-control" readonly required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Invoice Date</label>
                                    <input type="date" name="invoice_date" class="form-control" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Due Date</label>
                                    <input type="date" name="due_date" class="form-control" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Customer</label>
                                    <select name="customer_id" class="form-select" required>
                                        <option value="">Loading customers...</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Payment Status</label>
                                    <select name="status" class="form-select" id="invoiceStatus">
                                        <option value="pending">Pending</option>
                                        <option value="paid">Paid</option>
                                        <option value="due">Due</option>
                                    </select>
                                </div>
                                <!-- Paid Amount -->
                                <div class="col-md-6 d-none" id="paidAmountWrapper">
                                    <label class="form-label">Paid Amount</label>
                                    <input type="number" required name="paid_amount" class="form-control" placeholder="Enter paid amount">
                                    <small class="text-muted">Remaining: ₹ <span id="remainingAmount">0.00</span></small>
                                </div>

                                <!-- Payment Mode -->
                                <div class="col-md-6 d-none" id="paymentModeWrapper">
                                    <label class="form-label">Payment Mode</label>
                                    <select name="payment_mode" class="form-select" required>
                                        <option value="">Select Mode</option>
                                        <option value="cash">Cash</option>
                                        <option value="upi">UPI</option>
                                        <option value="card">Card</option>
                                        <option value="bank">Bank Transfer</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">Invoice Items</h6>
                            <div class="table-responsive">
                                <table class="table align-middle" id="itemsTable">
                                    <thead class="table-light">
                                    <tr>
                                        <th>Item</th>
                                        <th width="120">Qty</th>
                                        <th width="120">Stock</th>
                                        <th width="150">Rate</th>
                                        <th width="150">Total</th>
                                        <th width="50"></th>
                                    </tr>
                                    </thead>
                                    <tbody id="itemsTableBody">

                                    </tbody>
                                </table>
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="addItemBtn">
                                <i class="fa fa-plus me-1"></i> Add Item
                            </button>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-6 mb-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <h6 class="fw-semibold mb-3">Notes</h6>
                                    <textarea name="notes" class="form-control" rows="5"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 mb-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body">
                                    <h6 class="fw-semibold mb-3">Invoice Summary</h6>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Subtotal</span>
                                        <strong class="invoice-subtotal">₹ 0.00</strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Tax (%)</span>
                                        <input type="number" name="tax" class="form-control form-control-sm w-25 text-end">
                                    </div>
                                    <hr>
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold">Total</span>
                                        <span class="fw-bold fs-5 invoice-total" data-val="">₹ 0.00</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" onclick="resetInvoice()" class="btn btn-light">Reset</button>
                        <button type="button" class="btn btn-success saveAndPrint">
                            <i class="fa fa-print me-1"></i> Save & Print Invoice
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-save me-1"></i> Save Invoice
                        </button>
                    </div>
                </form>
            </div>

            <div id="showInvoicesView" class="view d-none">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0">All Invoices</h6>
                            <input type="text" class="form-control form-control-sm w-25" id="searchInput" placeholder="Search invoice">
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                <tr class="text-center">
                                    <th><input type="checkbox" id="selectAll"></th>
                                    <th>#</th>
                                    <th>Invoice No</th>
                                    <th>Customer</th>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Paid</th>
                                    <th>Due</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                                </thead>
                                <tbody id="invoiceTable">

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>
<!-- Edit Invoice Modal -->
