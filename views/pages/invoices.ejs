function resetInvoice() {
    invoiceForm.reset();

    const today = new Date().toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"]').forEach(input => input.value = today);

    document.querySelector('[name="tax"]').value = "<%= settings.defaultTax %>";

    itemsTableBody.innerHTML = "";

    // ✅ RESET PAYMENT UI
    const paidWrapper = document.getElementById("paidAmountWrapper");
    const paymentModeWrapper = document.getElementById("paymentModeWrapper");
    const paidInput = document.querySelector('[name="paid_amount"]');
    const remainingText = document.getElementById("remainingAmount");

    paidWrapper.classList.add("d-none");
    paymentModeWrapper.classList.add("d-none");

    paidInput.value = "";
    paidInput.removeAttribute("readonly");

    if (remainingText) remainingText.innerText = "0.00";

    // optional: reset payment mode
    const paymentMode = document.querySelector('[name="payment_mode"]');
    if (paymentMode) paymentMode.value = "";

    // ---------------- NORMAL RESET FLOW ----------------
    loadInvoice();
    addNewRow();
    updateSummary();
    loadInvoiceTable();
}
    function getOrdinal(n) {
        const s = ["th", "st", "nd", "rd"];
        const v = n % 100;
        return s[(v - 20) % 10] || s[v] || s[0];
    }
    function formatDate(dateString) {
        const date = new Date(dateString);

        const day = date.getDate(); 

        const month = date.toLocaleString('default', { month: 'short' }); 

        const year = date.getFullYear(); 

        return `${day}${getOrdinal(day)} ${month}, ${year}`;
    }
    const btnCreate = document.getElementById('btnCreateInvoice');
    const btnShow = document.getElementById('btnShowInvoices');
    const createView = document.getElementById('createInvoiceView');
    const showView = document.getElementById('showInvoicesView');
    const title = document.getElementById('pageTitle');
    const subtitle = document.getElementById('pageSubtitle');
    const invoiceForm = document.getElementById('invoiceForm');
    const itemsTableBody = document.getElementById('itemsTableBody');
    const addItemBtn = document.getElementById('addItemBtn');

    let globalProducts = [];
    let selectedProducts = [];

    function switchView(showCreate) {
        if (showCreate) {
            showView.classList.add('d-none');
            createView.classList.remove('d-none');
            setTimeout(() => { createView.classList.add('active-view'); showView.classList.remove('active-view'); }, 10);
            btnCreate.className = 'btn btn-primary active';
            btnShow.className = 'btn btn-outline-primary';
            title.innerText = 'Create Invoice';
            subtitle.innerText = 'Generate a new invoice for a customer';
        } else {
            createView.classList.add('d-none');
            showView.classList.remove('d-none');
            setTimeout(() => { showView.classList.add('active-view'); createView.classList.remove('active-view'); }, 10);
            btnShow.className = 'btn btn-primary active';
            btnCreate.className = 'btn btn-outline-primary';
            title.innerText = 'Invoices';
            subtitle.innerText = 'View and manage all generated invoices';
        }
    }

    btnCreate.addEventListener('click', () => switchView(true));
    btnShow.addEventListener('click', () => switchView(false));

    async function initializeData() {
        try {
            const [custRes, prodRes] = await Promise.all([
                fetch('/api/customers/read', { method: "POST", headers: { "Content-Type": "application/json" } }),
                fetch('/api/products/read', { method: "POST", headers: { "Content-Type": "application/json" } })
            ]);

            const customersData = await custRes.json();
            const productsData = await prodRes.json();

            const customers = customersData.data.customers || [];
            globalProducts = productsData.data || [];

            const customerSelect = document.querySelector('select[name="customer_id"]');
            customerSelect.innerHTML = '<option value="">Select Customer</option>';
            customers.forEach(c => {
                customerSelect.innerHTML += `<option value="${c._id}">${c.name} (${c.email})</option>`;
            });


            addNewRow();

        } catch (err) {
            console.error("Error loading initial data:", err);
            showToast("Failed to load customer/product data." , "danger");
        }
    }


function addNewRow() {
    const row = document.createElement('tr');
    row.innerHTML = `
        <td>
            <select name="product_id[]" class="form-select product-select" required>
                </select>
            <input type="hidden" name="item_name[]">
        </td>
        <td><input type="number" name="quantity[]" class="form-control" min="0" value="1"></td>
        <td><input type="number" readonly name="stock[]" class="form-control" min="0" ></td>
        <td><input type="number" name="price[]" class="form-control" step="0.01" value="0"></td>
        <td><input type="text" class="form-control row-total" readonly value="0.00"></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger remove-item"><i class="fa fa-trash"></i></button></td>
    `;
    itemsTableBody.appendChild(row);
    updateAllDropdowns();
}

    function updateAllDropdowns() {
        const allSelects = document.querySelectorAll('.product-select');
        const currentlySelectedIds = Array.from(allSelects)
            .map(select => select.value)
            .filter(id => id !== "");

        allSelects.forEach(select => {
            const currentValue = select.value;

            let html = '<option value="">Select Product</option>';

            globalProducts.forEach(p => {
                const isSelectedElsewhere = currentlySelectedIds.includes(p._id) && p._id !== currentValue;

                if (!isSelectedElsewhere) {
                    html += `<option value="${p._id}" 
                                data-price="${p.price}" 
                                data-stock="${p.stock}" 
                                ${p._id === currentValue ? 'selected' : ''}>
                                ${p.category} → ${p.name} → ${p.sku}
                             </option>`;
                }
            });

            select.innerHTML = html;
        });
    }
    addItemBtn.addEventListener('click', addNewRow);

    itemsTableBody.addEventListener('click', (e) => {
        if (e.target.closest('.remove-item')) {
            if (itemsTableBody.rows.length > 1) {
                e.target.closest('tr').remove();
                updateSummary();
                updateAllDropdowns();
            }
        }
    });

    itemsTableBody.addEventListener('change', (e) => {
        if (e.target.classList.contains('product-select')) {
            const row = e.target.closest('tr');
            const selectedOption = e.target.options[e.target.selectedIndex];
            const price = selectedOption.dataset.price || 0;
            const stock = selectedOption.dataset.stock || 0;
            
            row.querySelector('[name="price[]"]').value = price;
            row.querySelector('[name="stock[]"]').value = stock;
            row.querySelector('[name="item_name[]"]').value = selectedOption.text;
            calculateRowTotal(row);
            updateAllDropdowns();
        }
    });

    itemsTableBody.addEventListener('input', (e) => {
        if (e.target.name === 'quantity[]') {
            const row = e.target.closest('tr');
            const productSelect = row.querySelector('.product-select');
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            const stock = Number(selectedOption.dataset.stock || 0);
            let quantity = Number(e.target.value);
            if (quantity > stock) {
                e.target.value = stock;
                if (typeof showToast === 'function') {
                    showToast(`Maximum available stock is ${stock}`, "warning");
                } else {
                    showToast(`Maximum available stock is ${stock}` , "warning");
                }
            }
            calculateRowTotal(row);
        }
    });

    itemsTableBody.addEventListener('input', (e) => {
        if (e.target.name === 'quantity[]' || e.target.name === 'price[]') {
            calculateRowTotal(e.target.closest('tr'));
        }
    });

    function calculateRowTotal(row) {
        const qty = Number(row.querySelector('[name="quantity[]"]').value || 1);
        const price = Number(row.querySelector('[name="price[]"]').value || 0);
        const total = qty * price;
        row.querySelector('.row-total').value = total.toFixed(2);
        updateSummary();

    }

function updateSummary() {
    let subtotal = 0;
    document.querySelectorAll('.row-total').forEach(input => {
        subtotal += Number(input.value || 0);
    });

    const taxPercent = Number(document.querySelector('[name="tax"]').value || 0);
    const taxAmount = subtotal * (taxPercent / 100);
    const total = subtotal + taxAmount;

    document.querySelector('.invoice-subtotal').innerText =
        `₹ ${subtotal.toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;

    document.querySelector('.invoice-total').innerText =
        `₹ ${total.toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;

    // IMPORTANT: AUTO UPDATE PAID AMOUNT
    const status = document.getElementById("invoiceStatus").value;
    const paidInput = document.querySelector('[name="paid_amount"]');
    const remainingText = document.getElementById("remainingAmount");

    if (status === "paid") {
        paidInput.value = total.toFixed(2);
        if (remainingText) remainingText.innerText = "0.00";
    }
}

    async function saveInvoice()
    {
            const productIds = document.getElementsByName('product_id[]');
            const names = document.getElementsByName('item_name[]');
            const qtys = document.getElementsByName('quantity[]');
            const prices = document.getElementsByName('price[]');

            const items = [];
            for (let i = 0; i < productIds.length; i++) {
                if (!productIds[i].value) continue;
                items.push({
                    product_id: productIds[i].value,
                    name: names[i].value,
                    quantity: Number(qtys[i].value),
                    rate: Number(prices[i].value)
                });
            }

            if (items.length === 0) {
                showToast("Please add at least one product to the invoice." , "warning");
                return;
            }

            const payload = {
                inv_number: "<%= settings.invoicePrefix %>" + "-" + invoiceForm.invoice_no.value,
                inv_date: invoiceForm.invoice_date.value,
                due_date: invoiceForm.due_date.value,
                customer_id: invoiceForm.customer_id.value,
                status: invoiceForm.status.value,
                tax_percent: Number(invoiceForm.tax.value || 0),
                notes: invoiceForm.notes.value,
                items: items,
                created_by : "<%= payload.id %>"
            };

            try {
                const response = await fetch('/api/invoices/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success) {
                
                    const invoiceId = result.data._id;
                    const totalAmount = parseFloat(
                        document.querySelector(".invoice-total").innerText.replace(/[^\d.]/g, "")
                    );
                
                    let paymentAmount = 0;
                    let payment_status = "pending";
                    // ---------------- STATUS LOGIC ----------------
                    if (payload.status === "paid") {
                        paymentAmount = totalAmount;
                        payment_status = "completed"
                        
                    }
                    else if (payload.status === "due") {
                        const inputAmount = document.querySelector('[name="paid_amount"]').value;
                        paymentAmount = parseFloat(inputAmount || 0);
                    
                        if (paymentAmount <= 0 || paymentAmount > totalAmount) {
                            showToast("Enter valid paid amount", "warning");
                            return;
                        }
                    }

                    if ((payload.status === "paid" || payload.status === "due")) {
                        const mode = document.querySelector('[name="payment_mode"]').value;
                        if (!mode) {
                            showToast("Select payment mode", "warning");
                            return;
                        }
                    }

                    // ---------------- CREATE PAYMENT ----------------
                    if (payload.status === "paid" || payload.status === "due") {
                        let payment_status = "pending";
                        const paymentPayload = {
                            customer_id: payload.customer_id,
                            invoice_id: invoiceId,
                            amount: paymentAmount,
                            payment_mode: document.querySelector('[name="payment_mode"]').value || "cash", 
                            status : payment_status ,
                            payment_date: new Date().toISOString().split("T")[0],
                            notes: "Auto payment from invoice"
                        };
                    
                        try {
                            await fetch("/api/payments/create", {
                                method: "POST",
                                headers: {
                                    "Content-Type": "application/json"
                                },
                                body: JSON.stringify(paymentPayload)
                            });
                        
                        } catch (err) {
                            console.error("Payment Error:", err);
                            showToast("Payment creation failed", "danger");
                        }
                    }
                
                    // ---------------- UI SUCCESS ----------------
                    showToast(result.msg, "success");
                    updateInvoice();
                
                    setTimeout(() => {
                        resetInvoice();
                    }, 1000);
                
                    return result.data;
                } else {
                    showToast('Error: ' + (result.msg || 'Submission failed') , "warning");
                }
            } catch (error) {
                console.error("Submission Error:", error);
                showToast('A server error occurred.' , "danger");
            }
    }

    document.querySelector('[name="tax"]').addEventListener('input', updateSummary);


        invoiceForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            await saveInvoice();
        });

        document.querySelector(".saveAndPrint").addEventListener("click" , async (e)=>{
            e.preventDefault();
            if(validateInvoiceForm())
            {
                const data = await saveInvoice();
                printInvoice(data._id);
            }
        })

        function loadInvoiceTable() {
        const invoiceTableBody = document.getElementById("invoiceTable");

        invoiceTableBody.innerHTML = '<tr><td colspan="7" class="text-center">Loading invoices...</td></tr>';

        fetch("/api/invoices/read", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            }
        })
        .then(res => {
            if (!res.ok) throw new Error("Failed to fetch invoices");
            return res.json();
        })
        .then(result => {
            invoiceTableBody.innerHTML = "";

            const invoices = result.data || [];

            if (invoices.length === 0) {
                invoiceTableBody.innerHTML = '<tr><td colspan="9" class="text-center">NO INVOICES FOUND</td></tr>';
                return;
            }

            invoices.forEach((inv, i) => {
                const date = inv.inv_date ? new Date(inv.inv_date).toLocaleDateString() : 'N/A';

                const customerName = (inv.customer_id && inv.customer_id.name) 
                                     ? inv.customer_id.name 
                                     : (inv.customer_id || "Unknown");

                const statusClass = inv.status === 'paid' ? 'bg-success' : 
                                    inv.status === 'pending' ? 'bg-warning text-dark' : 'bg-danger';

                const row = `
                    <tr class='text-center'>
                        <td>
                            <input type="checkbox" class="row-checkbox" value="${inv._id}">
                        </td>
                        <td>${i + 1}</td>    
                        <td><strong>${inv.inv_number}</strong></td>    
                        <td>${customerName}</td>    
                        <td>${formatDate(date)}</td>
                        <td class="fw-bold">₹ ${Number(inv.total_amount || 0).toLocaleString('en-IN', {minimumFractionDigits: 2})}</td> 
                        <td class="fw-bold">₹ ${Number(inv.paid_amount || 0).toLocaleString('en-IN', {minimumFractionDigits: 2})}</td> 
                        <td class="fw-bold">₹ ${Number((inv.total_amount) - Number(inv.paid_amount || 0)).toLocaleString('en-IN', {minimumFractionDigits: 2})}</td> 
                        <td><span class="badge ${statusClass}">${inv.status.toUpperCase()}</span></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button onclick="viewInvoice('${inv._id}')" class="btn btn-outline-secondary"><i class="fa fa-eye"></i></button>
                                <button onclick="printInvoice('${inv._id}')" class="btn btn-outline-success"><i class="fa fa-print"></i></button>
                                <button onclick="downloadInvoice('${inv._id}')" class="btn btn-outline-dark"><i class="fa fa-download"></i></button>
                                <button onclick="editInvoice('${inv._id}')" class="btn btn-outline-warning ${inv.status == "pending" ? "d-block" : "d-none"}"><i class="fa fa-edit"></i></button>
                                <button onclick="deleteInvoice('${inv._id}')" class="btn btn-outline-danger"><i class="fa fa-trash"></i></button>
                            </div>
                        </td>    
                    </tr>
                `;
                invoiceTableBody.insertAdjacentHTML('beforeend', row);

            });
            document.getElementById("selectAll").checked = false;
            toggleBulkActions();
        })
        .catch(err => {
            console.error("Error:", err);
            invoiceTableBody.innerHTML = `<tr><td colspan="7" class="text-center text-danger">Error: ${err.message}</td></tr>`;
        });
    }

function addEditRow(item = null) {
    const tbody = document.getElementById("editItemsBody");
    const row = document.createElement('tr');
    
    let options = globalProducts.map(p => 
        `<option value="${p._id}" data-price="${p.price}" data-stock="${p.stock}" ${item && item.product_id === p._id ? 'selected' : ''}>
            ${p.name} (${p.sku})
        </option>`
    ).join('');

    row.innerHTML = `
        <td>
            <select class="form-select form-select-sm edit-product-select">
                <option value="">Select</option>
                ${options}
            </select>
        </td>
        <td><input type="number" class="form-control form-control-sm edit-qty" min="1" value="${item ? item.quantity : 1}"></td>
        <td><input type="number" class="form-control form-control-sm edit-stock bg-light" readonly value="${item ? (globalProducts.find(p=>p._id === item.product_id)?.stock || 0) : 0}"></td>
        <td><input type="number" class="form-control form-control-sm edit-rate bg-light" readonly value="${item ? item.rate : 0}"></td>
        <td class="edit-row-total">₹ ${(item ? item.quantity * item.rate : 0).toFixed(2)}</td>
        <td><button type="button" class="btn btn-sm text-danger" onclick="
        if (countEditItemsRow() > 1) {
            this.closest('tr').remove();
            updateEditSummary();
            updateEditDropdowns();
        } else {
            showToast('There should be at least one item', 'warning');
        }
        "><i class="fa fa-trash"></i></button></td>
    `;
    tbody.appendChild(row);
    updateEditDropdowns();
    row.addEventListener('input', (e) => {
        const qtyInput = row.querySelector('.edit-qty');
        const stockInput = row.querySelector('.edit-stock');
        const productSelect = row.querySelector('.edit-product-select');
        
        if (e.target.classList.contains('edit-product-select')) {
            const opt = productSelect.options[productSelect.selectedIndex];
            const stock = Number(opt.dataset.stock || 0);
            row.querySelector('.edit-rate').value = opt.dataset.price || 0;
            stockInput.value = stock;
            updateEditDropdowns();
        }

        if (e.target.classList.contains('edit-qty')) {
            const maxStock = Number(stockInput.value);
            if (Number(qtyInput.value) > maxStock) {
                qtyInput.value = maxStock;
                showToast(`Maximum available stock is ${maxStock}`, "warning");
            }
        }
        
        updateEditSummary();
    });
}
function updateEditSummary() {
    let subtotal = 0;
    document.querySelectorAll('#editItemsBody tr').forEach(row => {
        const qty = row.querySelector('.edit-qty').value;
        const rate = row.querySelector('.edit-rate').value;
        const total = qty * rate;
        row.querySelector('.edit-row-total').innerText = `₹ ${total.toFixed(2)}`;
        subtotal += total;
    });
    
    const tax = document.getElementById('editTaxPercent').value || 0;
    const finalTotal = subtotal + (subtotal * tax / 100);
    document.getElementById("editInvoiceTotal").innerText = finalTotal.toLocaleString('en-IN');
}

async function editInvoice(id) {
    try {
        const res = await fetch(`/api/invoices/read-one/`, { 
            method: "POST", 
            headers: {"Content-Type": "application/json"}, 
            body: JSON.stringify({ id }) 
        });
        const result = await res.json();
        const inv = result.data;

        const form = document.getElementById("editInvoiceForm");
        form.invoice_id.value = inv._id;
        form.inv_number.value = inv.inv_number;
        form.name.value = inv.customer_id.name;
        form.status.value = inv.status;
        
        form.inv_date.value = inv.inv_date ? new Date(inv.inv_date).toISOString().split('T')[0] : "";
        form.due_date.value = inv.due_date ? new Date(inv.due_date).toISOString().split('T')[0] : "";

        document.getElementById('editTaxPercent').value = inv.tax_percent;
        document.getElementById("editItemsBody").innerHTML = "";
        inv.items.forEach(item => addEditRow(item));
        updateEditSummary();

        new bootstrap.Modal(document.getElementById("editInvoiceModal")).show();
    } catch (err) {
        showToast("Error loading invoice", "danger");
    }
}

function updateEditDropdowns() {
    const allSelects = document.querySelectorAll('.edit-product-select');

    const selectedIds = Array.from(allSelects)
        .map(s => s.value)
        .filter(v => v !== "");

    allSelects.forEach(select => {
        const currentValue = select.value;

        let html = '<option value="">Select</option>';

        globalProducts.forEach(p => {
            const isUsedElsewhere =
                selectedIds.includes(p._id) && p._id !== currentValue;

            if (!isUsedElsewhere) {
                html += `
                    <option value="${p._id}"
                        data-price="${p.price}"
                        data-stock="${p.stock}"
                        ${p._id === currentValue ? 'selected' : ''}>
                        ${p.name} (${p.sku})
                    </option>
                `;
            }
        });

        select.innerHTML = html;
    });
}


async function updateEditedInvoice() {
    const form = document.getElementById("editInvoiceForm");
    const rows = document.querySelectorAll("#editItemsBody tr");
    const items = [];

    rows.forEach(row => {
        const select = row.querySelector(".edit-product-select");
        if (select.value) {
            items.push({
                product_id: select.value,
                name: select.options[select.selectedIndex].text,
                quantity: Number(row.querySelector(".edit-qty").value),
                rate: Number(row.querySelector(".edit-rate").value)
            });
        }
    });

    try {
        const res = await fetch("/api/invoices/update", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                id: form.invoice_id.value,
                updateData: {
                    items: items,
                    status: form.status.value,
                    inv_date: form.inv_date.value, 
                    due_date: form.due_date.value,  
                    tax_percent: Number(document.getElementById('editTaxPercent').value)
                }
            })
        });
        const result = await res.json();
        if (!result.success) throw new Error(result.msg);

        showToast(result.msg, "success");
        bootstrap.Modal.getInstance(document.getElementById("editInvoiceModal")).hide();
        loadInvoiceTable();
    } catch (err) {
        showToast(err.message, "danger");
    }
}

